# AWS workshop runtime
AWS_REGION=us-west-2
AWS_DEFAULT_REGION=us-west-2
AWS_ACCESS_KEY_ID=<replace-me>
AWS_SECRET_ACCESS_KEY=<replace-me>
AWS_SESSION_TOKEN=<replace-me>

# Workshop resources
CEW_GRAPH_NODES_TABLE=GraphNodes
CEW_GRAPH_EDGES_TABLE=GraphEdges
CEW_ARTIFACT_BUCKET=<replace-me>
BEDROCK_ENABLED=0
BEDROCK_INFERENCE_PROFILE_ID=us.anthropic.claude-opus-4-6-v1

